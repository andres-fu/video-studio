# Secrets
.env
*.key

# Episode outputs (rebuildable from raw + skill state)
episodes/*/edit/
episodes/*/motion-graphics/*.mp4
episodes/*/motion-graphics/*.webm
episodes/*/motion-graphics/.thumbnails/
episodes/*/final/*.mp4

# Keep the template directory tracked but its sample contents ignored
!episodes/_template/

# Raw source video — too big for git, store in cloud storage / external drive
episodes/*/raw/*.mp4
episodes/*/raw/*.mov
episodes/*/raw/*.MP4
episodes/*/raw/*.MOV

# Vendored skill (cloned by install.sh, not version-controlled here)
skills/video-use/

# Hyperframes scratch
node_modules/
.next/
.turbo/

# Claude session memory — personal, not for public repos
.claude/

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
